@model IEnumerable<ExamMSAppMVC.Models.Entities.Exam>
@{
    Layout = null; // Removing default layout to apply the Portal DNA
    ViewData["Title"] = "Student Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --portal-blue: #2B59FF;
            --portal-green: #2ECC71;
            --glass: rgba(255, 255, 255, 0.1);
            --glass-heavy: rgba(255, 255, 255, 0.15);
        }

        body {
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(43, 89, 255, 0.8)), 
                        url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1950&q=80');
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Poppins', sans-serif;
            color: white;
            min-height: 100vh;
        }

        /* Top Navigation Bar */
        .dashboard-nav {
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Dashboard Header */
        .welcome-section {
            padding: 40px 0;
        }

        .welcome-badge {
            background: rgba(46, 204, 113, 0.2);
            color: var(--portal-green);
            padding: 6px 15px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 1px;
            display: inline-block;
        }

        /* Filter Card */
        .filter-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 25px;
            padding: 30px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        }

        .form-select-custom {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            color: white !important;
            padding: 15px;
            border-radius: 15px;
        }

        .form-select-custom option { background: #1e293b; }

        /* Exam Cards */
        .exam-card {
            background: var(--glass-heavy);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 30px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            overflow: hidden;
            height: 100%;
        }

        .exam-card:hover {
            transform: translateY(-10px);
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid var(--portal-green);
            box-shadow: 0 15px 40px rgba(46, 204, 113, 0.2);
        }

        .duration-pill {
            background: rgba(43, 89, 255, 0.2);
            color: #8da2fb;
            border: 1px solid rgba(43, 89, 255, 0.3);
            border-radius: 12px;
            padding: 5px 12px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .btn-start {
            background: linear-gradient(135deg, var(--portal-blue), var(--portal-green));
            border: none;
            color: white;
            font-weight: 700;
            border-radius: 15px;
            padding: 12px;
            transition: 0.3s;
        }

        .btn-start:hover {
            transform: scale(1.02);
            color: white;
            box-shadow: 0 5px 20px rgba(46, 204, 113, 0.4);
        }

        .empty-state i {
            background: linear-gradient(135deg, #FFF, var(--portal-green));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>

    <nav class="dashboard-nav">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="navbar-brand d-flex align-items-center text-decoration-none" asp-controller="Home" asp-action="Index">
                <img src="~/images/ems-logo.jpg" style="height: 45px;" alt="Logo">
                <span class="ms-2 fw-bold text-white fs-4">EMS <span style="color:var(--portal-green)">Portal</span></span>
            </a>
            <div class="d-flex align-items-center">
                <div class="me-3 text-end d-none d-md-block">
                    <p class="mb-0 small fw-bold">Active Session</p>
                    <p class="mb-0 x-small text-success" style="font-size: 0.7rem;"><i class="fas fa-circle me-1"></i> Student</p>
                </div>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-light rounded-pill px-3">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="welcome-section text-center text-md-start">
            <span class="welcome-badge mb-2">DASHBOARD</span>
            <h1 class="fw-extrabold display-5">Welcome back, Student!</h1>
            <p class="text-white-50">Please select your course below to view available assessments.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 rounded-4 mb-4">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
            </div>
        }

        <div class="filter-card mb-5">
            <form method="get" asp-action="Index" class="row align-items-end g-3">
                <div class="col-md-9">
                    <label class="form-label small fw-bold text-uppercase opacity-75 ms-2">Select Your Subject</label>
                    <select name="courseId" class="form-select form-select-custom" 
                            asp-items="ViewBag.Courses" onchange="this.form.submit()">
                        <option value="">-- Click to view courses --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-start w-100 py-3">
                        <i class="fas fa-filter me-2"></i>Apply Filter
                    </button>
                </div>
            </form>
        </div>

        <div class="row g-4 mb-5">
            @if (Model != null && Model.Any())
            {
                @foreach (var exam in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card exam-card">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start mb-4">
                                    <div class="duration-pill">
                                        <i class="far fa-clock me-1"></i> @exam.DurationInMinutes Mins
                                    </div>
                                    <div class="text-white-50"><i class="fas fa-file-alt"></i></div>
                                </div>
                                
                                <h4 class="fw-bold mb-3">@exam.Title</h4>
                                <p class="small text-white-50 mb-4">Ensure you have a stable internet connection before beginning this assessment.</p>
                                
                                <div class="pt-3 border-top border-secondary border-opacity-25">
                                    <a asp-action="TakeExam" asp-route-id="@exam.Id" class="btn btn-start w-100">
                                        Start Attempt <i class="fas fa-chevron-right ms-2 small"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5 empty-state">
                    <i class="bi bi-journal-x display-1 mb-3 opacity-25"></i>
                    <h3 class="fw-bold">No Exams Found</h3>
                    <p class="text-white-50">Select a course above or check back later for new assignments.</p>
                </div>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>