@model IEnumerable<ExamMSAppMVC.Models.Entities.Exam>
@{
    Layout = "_Layout"; // Or null if you want a custom full-page look
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark">Student Dashboard</h2>
            <p class="text-secondary">Select your course to view upcoming assessments.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm p-4 mb-5" style="border-radius: 20px;">
        <form method="get" asp-action="Index" class="row align-items-end g-3">
            <div class="col-md-9">
                <label class="form-label fw-bold text-uppercase text-muted small">Current Course</label>
                <select name="courseId" class="form-select border-0 bg-light p-3" 
                        style="border-radius: 12px;" asp-items="ViewBag.Courses" onchange="this.form.submit()">
                    <option value="">-- Click to select a course --</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100 p-3 fw-bold" style="border-radius: 12px; background: #4361ee;">
                    <i class="bi bi-search me-2"></i>Find Exams
                </button>
            </div>
        </form>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var exam in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100 p-3" style="border-radius: 24px; transition: 0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-primary-subtle text-primary px-3 py-2" style="border-radius: 10px;">@exam.DurationInMinutes Mins</span>
                                <i class="bi bi-clock text-muted"></i>
                            </div>
                            <h5 class="fw-bold text-dark mb-2">@exam.Title</h5>
                            <p class="text-muted small mb-4">Click below to Start Exam.</p>
                            <a asp-action="TakeExam" asp-route-id="@exam.Id" class="btn btn-dark w-100 py-2 fw-bold" style="border-radius: 12px;">Start Attempt</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted">
                    <i class="bi bi-journal-x" style="font-size: 4rem;"></i>
                    <p class="mt-3">No exams available for this selection.</p>
                </div>
            </div>
        }
    </div>
</div>