@model ExamMSAppMVC.Models.Entities.Result

@{
    Layout = null;
    ViewData["Title"] = "Your Performance";

    string quote;
    string icon;
    string colorClass;

    if (Model.Percentage >= 75)
    {
        quote = "Mastermind Status! You've absolutely crushed this exam.";
        icon = "bi-trophy-fill";
        colorClass = "text-success";
    }
    else if (Model.Percentage >= 50)
    {
        quote = "Solid Effort! You've passed. Keep pushing for that top tier.";
        icon = "bi-star-fill";
        colorClass = "text-primary";
    }
    else
    {
        quote = "The comeback is always stronger than the setback. Study hard and go again!";
        icon = "bi-lightning-charge-fill";
        colorClass = "text-danger";
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card {
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
    </style>
</head>
<body>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0" style="border-radius: 20px;">
                <div class="card-body p-5 text-center">
                    
                    <div class="mb-4">
                        <i class="bi @icon @colorClass" style="font-size: 4rem;"></i>
                        <h3 class="mt-3 fw-bold">@quote</h3>
                    </div>

                    <div class="py-4 my-4 border-top border-bottom">
                        <p class="text-muted mb-1 text-uppercase fw-bold small">Score Percentage</p>
                        <h1 class="display-2 fw-bold @colorClass">@Model.Percentage%</h1>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block">Points</small>
                                <span class="h4 fw-bold">@Model.TotalScore</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3 border-start border-success border-4">
                                <small class="text-muted d-block">Correct</small>
                                <span class="h4 fw-bold text-success">@Model.CorrectAnswers</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 bg-light rounded-3 border-start border-danger border-4">
                                <small class="text-muted d-block">Wrong</small>
                                <span class="h4 fw-bold text-danger">@Model.WrongAnswers</span>
                            </div>
                        </div>
                        <div class="col-12 mt-3">
                            <div class="p-2 bg-light rounded-3">
                                <small class="text-muted">Exam taken on @Model.DateTaken.ToString("MMMM dd, yyyy")</small>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <a asp-action="Index" asp-controller="Student" class="btn btn-dark btn-lg w-100 fw-bold py-3" style="border-radius: 15px;">
                            Back to Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>