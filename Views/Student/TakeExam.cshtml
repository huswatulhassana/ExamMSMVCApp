@model ExamMSAppMVC.Models.Entities.Exam
@{
    Layout = null; // Important: Removes distractions
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Exam: @Model.Title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        body { background-color: #f8fafc; font-family: 'Segoe UI', sans-serif; }
        .exam-header { background: white; border-bottom: 1px solid #e2e8f0; padding: 1rem 0; position: sticky; top: 0; z-index: 1000; }
        .question-card { background: white; border-radius: 25px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.03); padding: 2.5rem; margin-bottom: 2rem; }
        .option-item { border: 2px solid #f1f5f9; border-radius: 15px; padding: 1.2rem; margin-bottom: 1rem; cursor: pointer; transition: 0.2s; display: flex; align-items: center; }
        .option-item:hover { border-color: #4361ee; background: #f0f3ff; }
        .option-item input { margin-right: 1.2rem; transform: scale(1.3); }
        .timer-box { background: #fff5f5; color: #e53e3e; padding: 0.6rem 1.2rem; border-radius: 12px; font-weight: 800; border: 1px solid #feb2b2; }
    </style>
</head>
<body>

    <header class="exam-header shadow-sm">
        <div class="container d-flex justify-content-between align-items-center">
            <div>
                <h5 class="fw-bold mb-0">@Model.Title</h5>
                <span class="text-muted small">Total Questions: @Model.Questions.Count</span>
            </div>
            <div class="timer-box">
                <i class="bi bi-stopwatch me-2"></i> <span id="timer">@Model.DurationInMinutes:00</span>
            </div>
            <button type="button" onclick="submitExam()" class="btn btn-danger px-4 fw-bold" style="border-radius:12px">Finish Exam</button>
        </div>
    </header>

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <form id="examForm" asp-action="SubmitExam" method="post">
                    <input type="hidden" name="examId" value="@Model.Id" />
                    
                    @foreach (var (q, index) in Model.Questions.Select((v, i) => (v, i)))
                    {
                        <div class="question-card">
                            <div class="d-flex justify-content-between mb-4">
                                <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 10px;">Question @(index + 1)</span>
                                <span class="text-primary fw-bold">@q.Marks Marks</span>
                            </div>
                            <h4 class="fw-bold mb-4 text-dark">@q.Text</h4>

                            <div class="options-list">
                                @foreach (var opt in new[] { ("A", q.OptionA), ("B", q.OptionB), ("C", q.OptionC), ("D", q.OptionD) })
                                {
                                    <label class="option-item">
                                        <input type="radio" name="answers[@q.Id]" value="@opt.Item1" required>
                                        <span class="fw-medium">@opt.Item2</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>
    </main>

    <script>
        function submitExam() {
            if(confirm("Submit your answers? You cannot change them later.")) {
                document.getElementById('examForm').submit();
            }
        }

        let timeLeft = @Model.DurationInMinutes * 60;
        const timerDisplay = document.getElementById('timer');

        const countdown = setInterval(() => {
            let mins = Math.floor(timeLeft / 60);
            let secs = timeLeft % 60;
            timerDisplay.innerHTML = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
            if (--timeLeft < 0) {
                clearInterval(countdown);
                alert("Time is up! Submitting automatically.");
                document.getElementById('examForm').submit();
            }
        }, 1000);
    </script>
</body>
</html>