@model ExamMSAppMVC.Models.Entities.Exam
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Exam: @Model.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    
    <style>
        :root {
            --portal-blue: #2B59FF;
            --portal-green: #2ECC71;
            --danger-red: #EF4444;
        }

        body { 
            background-color: #F1F5F9; 
            font-family: 'Poppins', sans-serif; 
            color: #1E293B;
        }

        /* 1. HIGH-VISIBILITY STICKY HEADER */
        .exam-header { 
            background: #0F172A; 
            color: white;
            padding: 1.2rem 0; 
            position: sticky; 
            top: 0; 
            z-index: 1000;
            border-bottom: 4px solid var(--portal-blue);
        }

        /* 2. THE ULTIMATE TIMER DESIGN */
        .timer-container {
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            padding: 10px 25px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.3s ease;
        }

        #timer {
            font-size: 1.8rem;
            font-weight: 800;
            font-family: 'Courier New', monospace; 
            letter-spacing: 1px;
        }

        .timer-warning {
            background: #FEF3C7 !important;
            color: #D97706 !important;
            border-color: #F59E0B !important;
            animation: pulse 1s infinite;
        }

        .timer-critical {
            background: #FEE2E2 !important;
            color: #DC2626 !important;
            border-color: #EF4444 !important;
            animation: shake 0.5s infinite;
        }

        .question-card { 
            background: white; 
            border-radius: 30px; 
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 15px 35px rgba(0,0,0,0.05); 
            padding: 3rem; 
            margin-bottom: 2.5rem; 
        }

        .option-item { 
            border: 2px solid #E2E8F0; 
            border-radius: 18px; 
            padding: 1.4rem; 
            margin-bottom: 1.2rem; 
            cursor: pointer; 
            transition: 0.3s; 
            display: flex; 
            align-items: center; 
        }

        .option-item:hover { 
            border-color: var(--portal-blue); 
            background: #F0F4FF; 
        }

        .option-item input[type="radio"]:checked + span {
            color: var(--portal-blue);
            font-weight: 700;
        }

        /* Animations */
        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @@keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }
    </style>
</head>
<body>

    <header class="exam-header">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-none d-md-block">
                <h5 class="fw-bold mb-0">@Model.Title</h5>
                <span class="text-white-50 small">Candidate Portal | @Model.Questions.Count Questions</span>
            </div>
            
            <div class="timer-container" id="timerWrapper">
                <i class="bi bi-alarm-fill fs-4"></i>
                <span id="timer">@Model.DurationInMinutes:00</span>
            </div>

            <button type="button" onclick="submitExam()" class="btn btn-danger px-4 fw-bold rounded-pill">
                Finalize & Submit
            </button>
        </div>
    </header>

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <form id="examForm" asp-action="SubmitExam" method="post">
                    <input type="hidden" name="examId" value="@Model.Id" />
                    
                    @foreach (var (q, index) in Model.Questions.Select((v, i) => (v, i)))
                    {
                        <div class="question-card">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <span class="badge rounded-pill bg-dark px-3 py-2">Question @(index + 1)</span>
                                <span class="fw-bold" style="color: var(--portal-blue)">@q.Marks Points</span>
                            </div>
                            
                            <h3 class="fw-bold mb-5">@q.Text</h3>

                            <div class="options-list">
                                @foreach (var opt in new[] { ("A", q.OptionA), ("B", q.OptionB), ("C", q.OptionC), ("D", q.OptionD) })
                                {
                                    <label class="option-item">
                                        <input type="radio" class="form-check-input me-3" name="answers[@q.Id]" value="@opt.Item1" required>
                                        <span class="fs-5">@opt.Item2</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </form>
            </div>
        </div>
    </main>

    <script>
        function submitExam() {
            if(confirm("Are you sure? Once submitted, you cannot edit your responses.")) {
                document.getElementById('examForm').submit();
            }
        }

        // --- TIMER LOGIC WITH VISUAL ALERTS ---
        let timeLeft = @Model.DurationInMinutes * 60;
        const timerDisplay = document.getElementById('timer');
        const timerWrapper = document.getElementById('timerWrapper');

        const countdown = setInterval(() => {
            let mins = Math.floor(timeLeft / 60);
            let secs = timeLeft % 60;
            
            timerDisplay.innerHTML = `${mins}:${secs < 10 ? '0' : ''}${secs}`;

            // Visual States
            if (timeLeft <= 300 && timeLeft > 60) { // 5 Minutes left (Warning)
                timerWrapper.classList.add('timer-warning');
            } 
            else if (timeLeft <= 60) { // 1 Minute left (Critical)
                timerWrapper.classList.remove('timer-warning');
                timerWrapper.classList.add('timer-critical');
            }

            if (--timeLeft < 0) {
                clearInterval(countdown);
                timerDisplay.innerHTML = "0:00";
                alert("TIME EXPIRED: Your assessment is being submitted automatically.");
                document.getElementById('examForm').submit();
            }
        }, 1000);
    </script>
</body>
</html>