@model IEnumerable<ExamMSAppMVC.Models.Entities.Question>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Question Bank - ExamMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    
    <style>
        :root {
            --bg-color: #f4f7fe;
            --sidebar-width: 260px;
            --primary-blue: #4361ee;
            --text-dark: #2d3748;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            display: flex;
        }

        .sidebar {
            width: var(--sidebar-width);
            background: #fff;
            height: 100vh;
            position: fixed;
            border-right: 1px solid #e2e8f0;
            padding: 20px;
        }

        .sidebar-brand {
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--primary-blue);
            margin-bottom: 30px;
            display: block;
            text-decoration: none;
        }

        .nav-link {
            color: #718096;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            text-decoration: none;
        }

        .nav-link i { margin-right: 12px; font-size: 1.2rem; }
        
        .nav-link.active {
            background: #fff;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
            color: var(--primary-blue);
        }

        /* Main Content */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            padding: 40px;
        }

        .content-card {
            background: white;
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 27px 0 rgba(0,0,0,0.05);
            overflow: hidden;
        }

        /* Table Styling */
        .table thead th {
            background-color: transparent;
            color: #a0aec0;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 1.5rem;
            border-bottom: 1px solid #f1f1f1;
        }

        .table tbody td {
            padding: 1.2rem 1.5rem;
            vertical-align: middle;
            border-top: 1px solid #f1f1f1;
        }

        .question-text {
            font-weight: 600;
            color: var(--text-dark);
            max-width: 350px;
            display: inline-block;
        }

        .option-preview {
            font-size: 0.75rem;
            color: #718096;
            display: block;
            line-height: 1.4;
        }

        .mark-badge {
            background: #f1f5f9;
            color: var(--primary-blue);
            font-weight: 700;
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 0.8rem;
        }

        .btn-add {
            background: var(--primary-blue);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 10px 20px;
            font-weight: 600;
        }

        .action-icon {
            color: #a0aec0;
            transition: 0.2s;
            font-size: 1.1rem;
        }

        .action-icon:hover { color: var(--primary-blue); }
        .delete-icon:hover { color: #e53e3e; }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="#" class="sidebar-brand">School Management</a>
        <nav>
            <a asp-controller="Admin" asp-action="Index" class="nav-link"><i class="bi bi-grid-fill"></i> Dashboard</a>
            <a asp-controller="Admin" asp-action="Courses" class="nav-link"><i class="bi bi-person-badge-fill"></i> Courses</a>
            <a asp-controller="Exam" asp-action="Index" class="nav-link"><i class="bi bi-calendar-event-fill"></i> Exam</a>
        </nav>
    </div>

    <div class="main-wrapper">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-0">Question Bank</h4>
                <p class="text-muted small">Manage and store exam questions centrally</p>
            </div>
            <a asp-action="Create" class="btn btn-add shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> Add New Question
            </a>
        </div>

        <div class="card content-card">
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Question Details</th>
                            <th>Correct</th>
                            <th class="text-center">Marks</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="question-text text-truncate mb-1">@q.Text</span>
                                    <div class="d-flex gap-3">
                                        <span class="option-preview">A: @q.OptionA</span>
                                        <span class="option-preview">B: @q.OptionB</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2" style="border-radius: 8px;">
                                        Option @q.CorrectOption
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="mark-badge">@q.Marks pts</span>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-3">
                                        <a asp-action="Edit" asp-route-id="@q.Id" class="action-icon" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@q.Id" method="post" onsubmit="return confirm('Delete this question?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="action-icon delete-icon border-0 bg-transparent p-0">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-folder-x text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-3">The question bank is currently empty.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>