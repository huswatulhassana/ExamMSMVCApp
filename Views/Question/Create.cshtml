@model List<ExamMSAppMVC.Models.DTOs.QuestionRequest>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Questions - ExamMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        :root { --bg-color: #f4f7fe; --primary-blue: #4361ee; --sidebar-width: 260px; }
        body { background-color: var(--bg-color); font-family: 'Segoe UI', sans-serif; display: flex; }
        .sidebar {
        width: 260px;
        background: #fff;
        height: 100vh;
        position: fixed;
        border-right: 1px solid #e2e8f0;
        padding: 20px;
    }

    .sidebar-brand {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--primary-blue);
        margin-bottom: 30px;
        display: block;
        text-decoration: none;
    }

    .nav-link {
        color: #718096;
        padding: 12px 15px;
        border-radius: 12px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        text-decoration: none;
    }
        .main-wrapper { margin-left: var(--sidebar-width); width: calc(100% - var(--sidebar-width)); padding: 40px; }
        .form-card { background: white; border-radius: 20px; box-shadow: 0 20px 27px 0 rgba(0,0,0,0.05); max-width: 850px; margin: 0 auto; }
        .btn-save { background: var(--primary-blue); color: white; border: none; border-radius: 12px; padding: 12px 35px; font-weight: 600; }
    </style>
</head>
<body>

   <div class="sidebar">
    <a href="#" class="sidebar-brand">School Management</a>
    <nav>
        <a asp-controller="Admin" asp-action="Index" class="nav-link"><i class="bi bi-grid-fill"></i> Dashboard</a>
        <a asp-controller="Admin" asp-action="Courses" class="nav-link"><i class="bi bi-person-badge-fill"></i> Courses</a>
        <a asp-controller="Exam" asp-action="Index" class="nav-link"><i class="bi bi-calendar-event-fill"></i> Exam</a>
    </nav>
</div>

    <div class="main-wrapper">
        <h4 class="fw-bold mb-4 text-center">Bulk Question Entry</h4>

        <div class="card form-card mb-4 p-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Select Course</label>
                <select id="courseSelector" class="form-select" asp-items="@(new SelectList(ViewBag.Courses, "Id", "Name"))">
                    <option value="">-- Select Course First --</option>
                </select>
            </div>
            <label class="form-label fw-bold">How many questions to add?</label>
            <div class="input-group">
                <input type="number" id="qCount" class="form-control" value="1" min="1" max="10">
                <button type="button" class="btn btn-primary" onclick="generateFields()">Generate Fields</button>
            </div>
        </div>

        <form asp-action="Create" method="post" id="bulkForm" style="display:none;">
            <div id="dynamicContainer"></div>
            <div class="text-center pt-4">
                <button type="submit" class="btn btn-save shadow-sm">Save All Questions</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 ms-2" style="border-radius: 12px;">Discard Changes</a>
            </div>
        </form>
    </div>

    <script>
        function generateFields() {
            const courseId = document.getElementById('courseSelector').value;
            if(!courseId) { alert("Please select a course first!"); return; }

            const count = document.getElementById('qCount').value;
            const container = document.getElementById('dynamicContainer');
            document.getElementById('bulkForm').style.display = 'block';
            container.innerHTML = '';
            
            for (let i = 0; i < count; i++) {
                container.innerHTML += `
                    <div class="card form-card mb-4 p-4">
                        <h6 class="text-primary fw-bold">Question ${i + 1}</h6>
                        <input type="hidden" name="[${i}].CourseId" value="${courseId}"> 
                        <textarea name="[${i}].Text" class="form-control mb-3" placeholder="Question Text" required></textarea>
                        <div class="row">
                            <div class="col-6"><input name="[${i}].OptionA" class="form-control mb-2" placeholder="Option A" required></div>
                            <div class="col-6"><input name="[${i}].OptionB" class="form-control mb-2" placeholder="Option B" required></div>
                            <div class="col-6"><input name="[${i}].OptionC" class="form-control mb-2" placeholder="Option C" required></div>
                            <div class="col-6"><input name="[${i}].OptionD" class="form-control mb-2" placeholder="Option D" required></div>
                        </div>
                        <select name="[${i}].CorrectOption" class="form-select mb-2" required>
                            <option value="">Select Correct Option</option>
                            <option value="A">A</option><option value="B">B</option>
                            <option value="C">C</option><option value="D">D</option>
                        </select>
                  <div class="col-6 mb-2">
                  <label class="form-label small fw-bold">Marks/Points</label>
                 <input name="[${i}].Marks" type="number" class="form-control" value="1" placeholder="e.g. 1">
                 </div>
                    </div>`;
            }
        }
    </script>
</body>
</html>