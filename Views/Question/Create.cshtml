@model ExamMSAppMVC.Models.DTOs.QuestionRequest
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Question - ExamMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    
    <style>
        :root {
            --bg-color: #f4f7fe;
            --sidebar-width: 260px;
            --primary-blue: #4361ee;
            --text-dark: #2d3748;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background: #fff;
            height: 100vh;
            position: fixed;
            border-right: 1px solid #e2e8f0;
            padding: 20px;
        }

        .sidebar-brand {
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--primary-blue);
            margin-bottom: 30px;
            display: block;
            text-decoration: none;
        }

        .nav-link {
            color: #718096;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            text-decoration: none;
        }

        .nav-link i { margin-right: 12px; font-size: 1.2rem; }
        
        .nav-link.active {
            background: #fff;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
            color: var(--primary-blue);
        }

        /* Main Content */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            padding: 40px;
        }

        .form-card {
            background: white;
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 27px 0 rgba(0,0,0,0.05);
            max-width: 850px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 0.7rem;
            font-weight: 800;
            color: #a0aec0;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #f1f1f1;
            padding-bottom: 10px;
            margin-bottom: 20px;
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #4a5568;
        }

        .form-control, .form-select {
            border-radius: 12px;
            padding: 12px 15px;
            border: 1px solid #e2e8f0;
            background-color: #f8fafc;
            transition: 0.2s;
        }

        .form-control:focus, .form-select:focus {
            background-color: #fff;
            border-color: var(--primary-blue);
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
        }

        .btn-save {
            background: var(--primary-blue);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 12px 35px;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-save:hover {
            background: #3651d1;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
        }

        .btn-back {
            background: #f1f5f9;
            color: #64748b;
            border-radius: 12px;
            padding: 12px 25px;
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="#" class="sidebar-brand">School Management</a>
        <nav>
            <a asp-controller="Admin" asp-action="Index" class="nav-link"><i class="bi bi-grid-fill"></i> Dashboard</a>
            <a asp-controller="Question" asp-action="Index" class="nav-link active"><i class="bi bi-database-fill"></i> Question Bank</a>
            <a asp-controller="Admin" asp-action="Courses" class="nav-link"><i class="bi bi-person-badge-fill"></i> Courses</a>
            <a asp-controller="Exam" asp-action="Index" class="nav-link"><i class="bi bi-calendar-event-fill"></i> Exam</a>
        </nav>
    </div>

    <div class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold mb-0">Add New Question</h4>
            <p class="text-muted small">Create a new entry for the global question bank</p>
        </div>

        <div class="card form-card">
            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post">
                    
                    <div class="section-title">General Information</div>
                    <div class="mb-4">
                        <label class="form-label">Associated Course</label>
                        <select asp-for="CourseId" class="form-select" 
                                asp-items="@(new SelectList(ViewBag.Courses, "Id", "Name"))">
                            <option value="">-- Select Course --</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Question Text</label>
                        <textarea asp-for="Text" class="form-control" rows="3" placeholder="Type the question content here..."></textarea>
                    </div>

                    <div class="section-title">Answer Options</div>
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label">Option A</label>
                            <input asp-for="OptionA" class="form-control" placeholder="Enter option A" required />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label">Option B</label>
                            <input asp-for="OptionB" class="form-control" placeholder="Enter option B" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label">Option C</label>
                            <input asp-for="OptionC" class="form-control" placeholder="Enter option C" required />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label">Option D</label>
                            <input asp-for="OptionD" class="form-control" placeholder="Enter option D" required />
                        </div>
                    </div>

                    <div class="section-title">Scoring</div>
                    <div class="row align-items-end">
                        <div class="col-md-6 mb-4">
                            <label class="form-label">Correct Option</label>
                            <select asp-for="CorrectOption" class="form-select" required>
                                <option value="">-- Select Correct Answer --</option>
                                <option value="A">Option A</option>
                                <option value="B">Option B</option>
                                <option value="C">Option C</option>
                                <option value="D">Option D</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label">Marks / Points</label>
                            <input asp-for="Marks" type="number" class="form-control" min="1" value="1" />
                        </div>
                    </div>

                    <div class="d-flex gap-3 pt-4">
                        <button type="submit" class="btn-save shadow-sm">Save Question</button>
                        <a asp-action="Index" class="btn-back">Discard Changes</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>