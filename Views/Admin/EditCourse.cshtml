@model ExamMSAppMVC.Models.DTOs.CourseResponse
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Course - ExamMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    
    <style>
        :root {
            --bg-color: #f4f7fe;
            --sidebar-width: 260px;
            --primary-blue: #4361ee;
            --text-dark: #2d3748;
        }

        body {
            background-color: var(--bg-color);
            font-family: 'Segoe UI', sans-serif;
            color: var(--text-dark);
            margin: 0;
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background: #fff;
            height: 100vh;
            position: fixed;
            border-right: 1px solid #e2e8f0;
            padding: 20px;
        }

        .sidebar-brand {
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--primary-blue);
            margin-bottom: 30px;
            display: block;
            text-decoration: none;
        }

        .nav-link {
            color: #718096;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            text-decoration: none;
        }

        .nav-link i { margin-right: 12px; font-size: 1.2rem; }
        
        .nav-link.active {
            background: #fff;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);
            color: var(--primary-blue);
        }

        /* Content */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            padding: 40px;
        }

        .form-card {
            background: white;
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 27px 0 rgba(0,0,0,0.05);
            max-width: 600px;
            margin: 0 auto;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 15px;
            border: 1px solid #e2e8f0;
            background-color: #f8fafc;
        }

        .form-control:focus {
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.15);
            border-color: var(--primary-blue);
        }

        .btn-update {
            background: var(--primary-blue);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 600;
            transition: 0.3s;
        }

        .btn-update:hover {
            background: #3651d1;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
        }

        .btn-back {
            background: #f1f5f9;
            color: #64748b;
            border-radius: 12px;
            padding: 12px;
            text-decoration: none;
            text-align: center;
            font-weight: 600;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="#" class="sidebar-brand">School Management</a>
        <nav>
            <a asp-controller="Admin" asp-action="Index" class="nav-link"><i class="bi bi-grid-fill"></i> Dashboard</a>
            <a asp-action="Courses" class="nav-link active"><i class="bi bi-person-badge-fill"></i> Courses</a>
            <a href="#" class="nav-link"><i class="bi bi-mortarboard-fill"></i> Student</a>
        </nav>
    </div>

    <div class="main-wrapper">
        <div class="mb-4">
            <h4 class="fw-bold mb-0">Modify Course</h4>
            <p class="text-muted small">Update details for @Model.CourseCode</p>
        </div>

        <div class="card form-card">
            <div class="card-body p-4 p-md-5">
                <form asp-action="EditCourse" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold text-secondary small">COURSE NAME</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Advanced C# Programming" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CourseCode" class="form-label fw-bold text-secondary small">COURSE CODE</label>
                        <input asp-for="CourseCode" class="form-control" placeholder="e.g. CS102" />
                        <span asp-validation-for="CourseCode" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-3 pt-2">
                        <button type="submit" class="btn btn-update">Update Course</button>
                        <a asp-action="Courses" class="btn btn-back">Cancel and Go Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>